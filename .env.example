# Copy to .env and fill in. Standard Postgres connection string — works with either
# a Supabase Postgres or a self-hosted Postgres (ADR-001 / ADR-014 portability).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local dev against the Docker Postgres used during testing:
# DATABASE_URL=postgresql://postgres:darsi@localhost:5433/darsi

# CORS: comma-separated list of allowed WebView origins. Default (unset) = "*",
# fine for local dev, NOT for production — /api/presence is a write endpoint.
# Origin = scheme+host only, NO trailing slash, NO spaces around commas.
# Produksi (Railway) WAJIB set ini ke origin WebView Vercel:
# CORS_ORIGINS=https://darsi-indoor-navigation.vercel.app

# Shared secret checked against the X-Admin-Token header on POST /api/poi/sync
# (T3.4-L2 — Unity Editor push). Pick any long random string; put the same value
# into the Unity POI Sync window (DARSI > Sync POIs to Backend).
POI_SYNC_TOKEN=change-me
