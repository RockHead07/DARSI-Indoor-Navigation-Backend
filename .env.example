# Copy to .env and fill in. Standard Postgres connection string — works with either
# a Supabase Postgres or a self-hosted Postgres (ADR-001 / ADR-014 portability).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local dev against the Docker Postgres used during testing:
# DATABASE_URL=postgresql://postgres:darsi@localhost:5433/darsi
